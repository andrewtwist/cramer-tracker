# =============================================
# Cramer vs Portfolio Tracker - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub!
# =============================================

# Supabase - get from https://app.supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Stock Price API
# Using Yahoo Finance (free, no key required) via cors-anywhere or allorigins proxy
# OR sign up free at https://finnhub.io for a free tier API key (60 req/min)
# Free option 1: Yahoo Finance (no key needed)
VITE_STOCK_API=yahoo

# Free option 2: Finnhub (60 req/min free tier)
# VITE_STOCK_API=finnhub
# VITE_FINNHUB_API_KEY=your_finnhub_api_key

# Admin setup
# After creating your admin account, run in Supabase SQL editor:
# UPDATE profiles SET is_admin = TRUE WHERE username = 'your_username';
